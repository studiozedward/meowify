{
  "manifest_version": 3,
  "name": "Meowify",
  "version": "1.1.1",
  "description": "Highlight text to turn it into meows, and back. Works in Gmail, Docs, chat apps and more.",
  "permissions": ["clipboardWrite", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_title": "Meowify" },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "cat-mode.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["confused_cat.jpg", "meowify-logo.png", "nunito-latin.woff2"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
