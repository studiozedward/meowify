{
  "manifest_version": 3,
  "name": "Meowify",
  "version": "1.0.0",
  "description": "Highlight text to turn it into meows, and back. Works in Gmail, Docs, chat apps and more.",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_title": "Meowify" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["confused_cat.jpg"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}